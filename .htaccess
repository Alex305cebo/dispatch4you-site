# Apache конфигурация для dispatch4you.com

# Включение mod_rewrite
RewriteEngine On

# favicon.ico -> favicon.svg
RewriteRule ^favicon\.ico$ favicon.svg [L,T=image/svg+xml]

# Редирект с www на без www
RewriteCond %{HTTP_HOST} ^www\.dispatch4you\.com [NC]
RewriteRule ^(.*)$ https://dispatch4you.com/$1 [L,R=301]

# Редирект HTTP на HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ========================================
# Стандартные пути с /pages/
# ========================================

# Кэширование статических файлов
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType audio/mpeg "access plus 1 year"
  # HTML не кешируем
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Разрешаем запросы к Groq API (для симулятора)
<IfModule mod_headers.c>
  # CSP управляется на уровне Hostinger — не переопределяем здесь
  # Header always set Content-Security-Policy "..."
</IfModule>

# Отключаем кеш для файлов симулятора
<FilesMatch "(simulator\.html|scenarios-inline\.js|scenarios-data.*\.js)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </IfModule>
</FilesMatch>

# Сжатие файлов
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Защита файлов конфигурации
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

# Защита от просмотра директорий
Options -Indexes

# Кастомные страницы ошибок (опционально)
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html
