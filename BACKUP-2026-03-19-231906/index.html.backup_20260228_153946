            const loadsElements = dropdown.querySelectorAll('.state-loads');
            loadsElements.forEach((element, index) => {
              const originalLoads = regionData.states[index].loads;
              let currentLoads = originalLoads;

              function animateLoads() {
                // Маленький шаг: изменение на ±1-3%
                const smallStep = (Math.random() * 0.04 - 0.02); // от -0.02 до +0.02 (±2%)
                currentLoads = currentLoads * (1 + smallStep);

                // Ограничиваем диапазон: -10% до +15% от оригинала
                const minLoads = originalLoads * 0.9;
                const maxLoads = originalLoads * 1.15;
                currentLoads = Math.max(minLoads, Math.min(maxLoads, currentLoads));

                element.textContent = `📦 ${Math.round(currentLoads)} грузов`;

