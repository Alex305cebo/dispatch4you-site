<!DOCTYPE html>
<html lang="ru">

<head>
  <!-- Auto-deploy test: 2026-02-25 23:50 - New webhook -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Курсы Диспетчера | Профессиональное обучение</title>
  <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #6366f1;
      --primary-dark: #4f46e5;
      --secondary: #8b5cf6;
      --accent: #ec4899;
      --bg-dark: #0f172a;
      --bg-darker: #020617;
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg-darker);
      color: var(--text-primary);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      transition: background 0.3s ease, color 0.3s ease;
      width: 100%;
      max-width: 100vw;
    }

    * {
      box-sizing: border-box;
    }

    html {
      overflow-x: hidden;
      width: 100%;
      max-width: 100vw;
    }

    /* Animated gradient background */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: transparent;
      pointer-events: none;
      z-index: 0;
      transition: opacity 0.3s ease;
    }

    /* Neural Background Canvas */
    #neuralCanvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      pointer-events: none;
      opacity: 1;
      display: block;
      filter: blur(4px);
      /* Увеличили размытие с 2px до 4px */
    }

    /* Grid pattern overlay */
    body::after {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-image:
        linear-gradient(rgba(99, 102, 241, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(99, 102, 241, 0.03) 1px, transparent 1px);
      background-size: 50px 50px;
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 32px;
    }

    @media (max-width: 768px) {
      .container {
        padding: 0 20px;
        max-width: 100%;
        width: 100%;
        box-sizing: border-box;
      }
    }

    @media (max-width: 480px) {
      .container {
        padding: 0 16px;
        width: 100%;
        box-sizing: border-box;
      }
    }

    @media (max-width: 360px) {
      .container {
        padding: 0 12px;
        width: 100%;
        box-sizing: border-box;
      }
    }

    /* Hero Section */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding: 70px 0 40px;
    }

    .hero::before {
      display: none !important;
    }

    .hero-content {
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
      padding: 0 20px;
      width: 100%;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 16px;
      background: rgba(99, 102, 241, 0.1);
      border: 1px solid rgba(99, 102, 241, 0.3);
      border-radius: 100px;
      font-size: 13px;
      font-weight: 600;
      color: var(--primary);
      margin-bottom: 24px;
      backdrop-filter: blur(10px);
      animation: fadeInUp 0.6s ease;
    }

    .badge-dot {
      width: 8px;
      height: 8px;
      background: var(--primary);
      border-radius: 50%;
      animation: pulse 2s ease infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
        transform: scale(1);
      }

      50% {
        opacity: 0.5;
        transform: scale(1.2);
      }
    }

    h1 {
      font-size: clamp(32px, 6vw, 56px);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
      animation: fadeInUp 0.8s ease 0.2s both;
    }

    .gradient-text {
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      background-size: 200% 200%;
      animation: gradientFlow 8s ease infinite;
    }

    @keyframes gradientFlow {

      0%,
      100% {
        background-position: 0% 50%;
      }

      50% {
        background-position: 100% 50%;
      }
    }

    .subtitle {
      font-size: clamp(14px, 2.5vw, 18px);
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto 32px;
      line-height: 1.6;
      animation: fadeInUp 1s ease 0.4s both;
    }

    .cta-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      animation: fadeInUp 1.2s ease 0.6s both;
      width: 100%;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 14px 28px;
      font-size: 15px;
      font-weight: 600;
      text-decoration: none;
      border-radius: 16px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      box-shadow: 0 10px 40px rgba(99, 102, 241, 0.4);
    }

    .btn-primary:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 60px rgba(99, 102, 241, 0.6);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.05);
      color: var(--text-primary);
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.2);
      transform: translateY(-2px);
    }

    /* Glass Button with Frosted Effect */
    .btn-glass {
      background: rgba(99, 102, 241, 0.15);
      color: white;
      border: 1px solid rgba(99, 102, 241, 0.3);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 8px 32px rgba(99, 102, 241, 0.2),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
    }

    .btn-glass:hover {
      background: rgba(99, 102, 241, 0.25);
      border-color: rgba(99, 102, 241, 0.5);
      transform: translateY(-4px);
      box-shadow: 0 12px 48px rgba(99, 102, 241, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    /* Chat Button Styles */
    .btn-chat {
      position: relative;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(59, 130, 246, 0.2));
      color: white;
      border: 2px solid rgba(139, 92, 246, 0.5);
      backdrop-filter: blur(10px);
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(139, 92, 246, 0.3);
    }

    .btn-chat::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.5s;
    }

    .btn-chat:hover::before {
      left: 100%;
    }

    .btn-chat:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 60px rgba(139, 92, 246, 0.5);
      border-color: rgba(139, 92, 246, 0.8);
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), rgba(59, 130, 246, 0.3));
    }

    .chat-icon {
      display: inline-block;
      font-size: 1.2em;
      animation: chatBounce 2s ease-in-out infinite;
    }

    @keyframes chatBounce {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-3px);
      }
    }

    .chat-pulse {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100%;
      height: 100%;
      transform: translate(-50%, -50%);
      border-radius: 12px;
      background: rgba(139, 92, 246, 0.3);
      animation: pulse 2s ease-out infinite;
      pointer-events: none;
      z-index: -1;
    }

    @keyframes pulse {
      0% {
        transform: translate(-50%, -50%) scale(1);
        opacity: 0.5;
      }

      100% {
        transform: translate(-50%, -50%) scale(1.5);
        opacity: 0;
      }
    }

    .arrow {
      transition: transform 0.3s;
    }

    .btn:hover .arrow {
      transform: translateX(4px);
    }

    /* Mobile Responsive для Hero */
    @media (max-width: 768px) {
      .hero {
        min-height: auto;
        padding: 140px 0 60px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .hero-content {
        padding: 0 16px;
        text-align: center;
        width: 100%;
        max-width: 100%;
      }

      h1 {
        font-size: clamp(28px, 8vw, 40px);
        margin-bottom: 16px;
        text-align: center;
      }

      .subtitle {
        font-size: clamp(14px, 3vw, 16px);
        margin-bottom: 28px;
        text-align: center;
      }

      .badge {
        font-size: 12px;
        padding: 5px 14px;
        margin-bottom: 20px;
        margin-left: auto;
        margin-right: auto;
      }

      .cta-buttons {
        gap: 12px;
        justify-content: center;
        align-items: center;
      }

      .btn {
        padding: 12px 24px;
        font-size: 14px;
        gap: 10px;
      }
    }

    @media (max-width: 480px) {
      .hero {
        padding: 120px 0 50px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .hero-content {
        padding: 0 12px;
        text-align: center;
        width: 100%;
      }

      h1 {
        font-size: clamp(24px, 9vw, 32px);
        margin-bottom: 12px;
        line-height: 1.2;
        text-align: center;
      }

      .subtitle {
        font-size: 14px;
        margin-bottom: 24px;
        line-height: 1.5;
        text-align: center;
      }

      .badge {
        font-size: 11px;
        padding: 4px 12px;
        gap: 4px;
        margin-bottom: 16px;
        display: inline-flex;
      }

      .badge-dot {
        width: 6px;
        height: 6px;
      }

      .cta-buttons {
        flex-direction: column;
        gap: 10px;
        width: 100%;
        align-items: center;
      }

      .btn {
        width: 100%;
        max-width: 320px;
        justify-content: center;
        padding: 12px 20px;
        font-size: 13px;
      }
    }

    @media (max-width: 360px) {
      .hero {
        padding: 70px 0 40px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .hero-content {
        padding: 0 10px;
        text-align: center;
      }

      h1 {
        font-size: 22px;
        text-align: center;
      }

      .subtitle {
        font-size: 13px;
        text-align: center;
      }

      .btn {
        padding: 10px 18px;
        font-size: 12px;
        max-width: 280px;
      }
    }

    /* Marquee Section */
    @keyframes marquee {
      from {
        transform: translateX(0);
      }

      to {
        transform: translateX(-50%);
      }
    }

    .hero-marquee {
      margin-top: 60px;
      position: relative;
      overflow: hidden;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.03);
      padding: 32px 0;
      backdrop-filter: blur(24px);
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;
    }

    .marquee-title {
      margin-bottom: 24px;
      padding: 0 32px;
      font-size: 14px;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.6);
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .marquee-wrapper {
      position: relative;
      display: flex;
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);
    }

    .marquee-content {
      display: flex;
      gap: 48px;
      white-space: nowrap;
      padding: 0 16px;
      animation: marquee 60s linear infinite;
      will-change: transform;
    }

    .brand-item {
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: 0.5;
      transition: all 0.3s ease;
      cursor: default;
      filter: grayscale(1);
    }

    .brand-item:hover {
      opacity: 1;
      transform: scale(1.05);
      filter: grayscale(0);
    }

    .brand-icon {
      height: 24px;
      width: 24px;
      color: white;
      fill: currentColor;
    }

    .brand-name {
      font-size: 18px;
      font-weight: 700;
      color: white;
      letter-spacing: -0.025em;
    }

    @media (max-width: 768px) {
      .hero-marquee {
        display: none;
      }
    }

    .marquee-content {
      gap: 20px;
      animation: marquee 35s linear infinite;
    }

    .brand-icon {
      height: 14px;
      width: 14px;
    }

    .brand-name {
      font-size: 11px;
    }

    /* Features Grid */
    .features {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 80px 0;
      position: relative;
    }

    .features::before {
      content: '01';
      position: absolute;
      top: 80px;
      right: 40px;
      font-size: 120px;
      font-weight: 900;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(236, 72, 153, 0.15));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      z-index: 0;
      pointer-events: none;
      line-height: 1;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      margin-top: 80px;
      width: 100%;
    }

    .feature-card {
      padding: 40px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 24px;
      backdrop-filter: blur(10px);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
      user-select: none;
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      box-sizing: border-box;
    }

    .feature-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, var(--primary), var(--secondary), var(--accent));
      transform: scaleX(0);
      transition: transform 0.4s;
    }

    .feature-card:hover::before {
      transform: scaleX(1);
    }

    .feature-card:hover {
      transform: translateY(-8px);
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(99, 102, 241, 0.3);
      box-shadow: 0 20px 60px rgba(99, 102, 241, 0.2);
    }

    .feature-icon {
      width: 64px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(139, 92, 246, 0.2));
      border-radius: 16px;
      font-size: 32px;
      margin-bottom: 24px;
      transition: all 0.3s;
      cursor: pointer;
    }

    .feature-card:hover .feature-icon {
      transform: scale(1.1) rotate(5deg);
    }

    /* Mobile-only card - hidden on desktop */
    .feature-card.mobile-only {
      display: none;
    }

    @media (max-width: 768px) {
      .feature-card.mobile-only {
        display: flex;
      }
    }

    .feature-icon:hover {
      transform: scale(1.3) rotate(15deg) translateY(-5px) !important;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.4), rgba(139, 92, 246, 0.4));
      box-shadow: 0 0 30px rgba(99, 102, 241, 0.6), 0 0 60px rgba(139, 92, 246, 0.4);
      filter: brightness(1.2);
    }

    .feature-badge {
      position: absolute;
      top: 16px;
      right: 16px;
      padding: 4px 10px;
      background: rgba(99, 102, 241, 0.15);
      border: 1px solid rgba(99, 102, 241, 0.3);
      border-radius: 6px;
      font-size: 9px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: rgba(99, 102, 241, 0.9);
      backdrop-filter: blur(10px);
      z-index: 2;
      transition: all 0.3s ease;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
    }

    .feature-badge:hover {
      background: rgba(99, 102, 241, 0.3);
      border-color: rgba(99, 102, 241, 0.6);
      color: #6366f1;
      box-shadow: 0 0 20px rgba(99, 102, 241, 0.6), 0 0 40px rgba(99, 102, 241, 0.3);
      transform: scale(1.05);
    }

    .feature-badge:active {
      animation: evaporate 0.6s ease forwards;
    }

    @keyframes evaporate {
      0% {
        opacity: 1;
        transform: scale(1.05);
      }

      50% {
        opacity: 0.5;
        transform: scale(1.3);
        filter: blur(4px);
      }

      100% {
        opacity: 0;
        transform: scale(2);
        filter: blur(10px);
      }
    }

    @keyframes pulse-badge {

      0%,
      100% {
        transform: scale(1);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
      }

      50% {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(16, 185, 129, 0.6);
      }
    }

    .feature-card h3 {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text-primary);
      text-align: center;
    }

    .feature-card p {
      font-size: 16px;
      color: var(--text-secondary);
      line-height: 1.7;
    }

    /* Stats Section */
    .stats {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 80px 0;
      position: relative;
    }

    .stats::before {
      content: '02';
      position: absolute;
      top: 80px;
      right: 40px;
      font-size: 120px;
      font-weight: 900;
      background: linear-gradient(135deg, rgba(236, 72, 153, 0.15), rgba(99, 102, 241, 0.15));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      z-index: 0;
      pointer-events: none;
      line-height: 1;
    }

    .diesel-section::before {
      display: none;
    }

    .rates-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 32px;
      margin-bottom: 48px;
    }

    .rates-section {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 20px;
      padding: 32px;
      transition: all 0.3s ease;
    }

    .rates-section:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(99, 102, 241, 0.3);
      transform: translateY(-4px);
    }

    .rates-section[data-type="diesel"] {
      cursor: pointer;
      user-select: none;
    }

    .rates-section[data-type="diesel"]:hover {
      background: rgba(245, 158, 11, 0.08);
      border-color: rgba(245, 158, 11, 0.3);
    }

    .rates-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }

    .rates-icon {
      font-size: 40px;
      flex-shrink: 0;
    }

    .rates-header h3 {
      font-size: 24px;
      font-weight: 700;
      color: #ffffff;
      flex: 1;
      min-width: 100px;
    }

    .rates-badge {
      padding: 6px 16px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(139, 92, 246, 0.2));
      border: 1px solid rgba(99, 102, 241, 0.3);
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
      color: #a5b4fc;
      white-space: nowrap;
    }

    .rates-chart {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .rate-bar-container {
      opacity: 0;
      animation: fadeInUp 0.6s ease-out forwards;
    }

    .rate-bar-container:nth-child(1) {
      animation-delay: 0.1s;
    }

    .rate-bar-container:nth-child(2) {
      animation-delay: 0.2s;
    }

    .rate-bar-container:nth-child(3) {
      animation-delay: 0.3s;
    }

    .rate-bar-container:nth-child(4) {
      animation-delay: 0.4s;
    }

    .rate-bar-container:nth-child(5) {
      animation-delay: 0.5s;
    }

    /* Новые современные полоски */
    .rate-bar-modern {
      position: relative;
      height: 70px;
      margin-bottom: 16px;
      border-radius: 16px;
      overflow: hidden;
      opacity: 0;
      animation: fadeInUp 0.6s ease-out forwards;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .rate-bar-modern:nth-child(1) {
      animation-delay: 0.1s;
    }

    .rate-bar-modern:nth-child(2) {
      animation-delay: 0.2s;
    }

    .rate-bar-modern:nth-child(3) {
      animation-delay: 0.3s;
    }

    .rate-bar-modern:nth-child(4) {
      animation-delay: 0.4s;
    }

    .rate-bar-modern:nth-child(5) {
      animation-delay: 0.5s;
    }

    .rate-bar-modern:hover {
      transform: translateY(-4px) scale(1.02);
      box-shadow: 0 12px 32px rgba(99, 102, 241, 0.3);
    }

    .rate-bar-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      backdrop-filter: blur(10px);
    }

    .rate-bar-fill {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      background: linear-gradient(90deg,
          rgba(99, 102, 241, 0.3),
          rgba(139, 92, 246, 0.2));
      border-radius: 16px;
      animation: fillBarSmooth 1.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      transform-origin: left;
      box-shadow: inset 0 2px 8px rgba(255, 255, 255, 0.1);
    }

    .rate-bar-modern:nth-child(1) .rate-bar-fill {
      background: linear-gradient(90deg, rgba(16, 185, 129, 0.4), rgba(16, 185, 129, 0.2));
    }

    .rate-bar-modern:nth-child(2) .rate-bar-fill {
      background: linear-gradient(90deg, rgba(99, 102, 241, 0.4), rgba(99, 102, 241, 0.2));
    }

    .rate-bar-modern:nth-child(3) .rate-bar-fill {
      background: linear-gradient(90deg, rgba(139, 92, 246, 0.4), rgba(139, 92, 246, 0.2));
    }

    .rate-bar-modern:nth-child(4) .rate-bar-fill {
      background: linear-gradient(90deg, rgba(236, 72, 153, 0.4), rgba(236, 72, 153, 0.2));
    }

    .rate-bar-modern:nth-child(5) .rate-bar-fill {
      background: linear-gradient(90deg, rgba(245, 158, 11, 0.4), rgba(245, 158, 11, 0.2));
    }

    /* Hidden rate bars */
    .rate-bar-hidden {
      display: none;
      opacity: 0;
      max-height: 0;
      margin: 0;
      overflow: hidden;
    }

    .rates-section.expanded .rate-bar-hidden {
      display: block;
      opacity: 1;
      max-height: 100px;
      margin-bottom: 16px;
      animation: fadeInUp 0.4s ease-out forwards;
    }

    /* Expand button */
    .rates-expand-btn {
      width: 100%;
      padding: 12px 20px;
      margin-top: 8px;
      background: rgba(99, 102, 241, 0.1);
      border: 1px solid rgba(99, 102, 241, 0.3);
      border-radius: 12px;
      color: var(--text-primary);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: all 0.3s ease;
    }

    .rates-expand-btn:hover {
      background: rgba(99, 102, 241, 0.2);
      border-color: rgba(99, 102, 241, 0.5);
      transform: translateY(-2px);
    }

    .expand-icon {
      transition: transform 0.3s ease;
      font-size: 12px;
    }

    .rates-section.expanded .expand-icon {
      transform: rotate(180deg);
    }

    @keyframes fillBarSmooth {
      from {
        width: 0;
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }

    .rate-bar-content {
      position: relative;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 24px;
      height: 100%;
      z-index: 2;
    }

    .rate-bar-modern:hover .rate-bar-content {
      transform: translateX(8px);
      transition: transform 0.3s ease;
    }

    .region-name {
      font-size: 18px;
      font-weight: 700;
      color: #ffffff;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
      letter-spacing: 0.5px;
    }

    .rate-value {
      font-size: 24px;
      font-weight: 900;
      background: linear-gradient(135deg, #ffffff, #a5b4fc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 2px 16px rgba(99, 102, 241, 0.5);
    }

    .rate-bar-glow {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
      border-radius: 16px;
    }

    .rate-bar-modern:hover .rate-bar-glow {
      opacity: 0.6;
      animation: glowPulse 2s ease-in-out infinite;
    }

    @keyframes glowPulse {

      0%,
      100% {
        opacity: 0.4;
      }

      50% {
        opacity: 0.8;
      }
    }

    /* Выпадающая вкладка с информацией по штатам - компактная версия */
    .states-dropdown {
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      margin-bottom: 12px;
    }

    .states-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      padding: 12px;
      background: rgba(0, 0, 0, 0.4);
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .states-info {
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .states-info .state-card {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 12px;
      transition: all 0.2s ease;
    }

    .states-info .state-card:hover {
      background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(245, 158, 11, 0.1));
      border-color: rgba(245, 158, 11, 0.4);
      transform: translateY(-2px);
    }

    .states-info .state-name {
      font-size: 14px;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 8px;
    }

    .states-info .state-details {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .states-info .city-name {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.7);
    }

    .states-info .fuel-price {
      font-size: 14px;
      font-weight: 600;
      color: #f59e0b;
    }

    @media (max-width: 768px) {
      .states-grid {
        grid-template-columns: 1fr;
        padding: 10px;
        gap: 6px;
      }
    }

    .state-item {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 10px 12px;
      transition: all 0.2s ease;
    }

    .state-item:hover {
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(139, 92, 246, 0.1));
      border-color: rgba(99, 102, 241, 0.4);
      transform: translateY(-1px);
    }

    .state-name {
      font-size: 13px;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 6px;
    }

    .state-city {
      font-size: 11px;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.7);
    }

    @media (max-width: 768px) {
