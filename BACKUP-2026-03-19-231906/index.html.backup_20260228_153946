      rateBars.forEach(bar => {
        bar.style.cursor = 'pointer';

        bar.addEventListener('click', function () {
          const regionName = this.querySelector('.region-name').textContent;
          const section = this.closest('.rates-section');
          const sectionTitle = section.querySelector('h3').textContent.toLowerCase();

          // Определяем тип оборудования
          let equipmentType = 'dryvan';
          if (sectionTitle.includes('reefer')) equipmentType = 'reefer';
          if (sectionTitle.includes('flatbed')) equipmentType = 'flatbed';
          if (sectionTitle.includes('car hauler')) equipmentType = 'carhauler';

          const regionData = ratesData[equipmentType][regionName];

          if (!regionData) return;

          // Проверяем, есть ли уже открытая вкладка
          let existingDropdown = this.nextElementSibling;
          if (existingDropdown && existingDropdown.classList.contains('states-dropdown')) {
            // Закрываем
            existingDropdown.style.maxHeight = '0';
            existingDropdown.style.opacity = '0';
            setTimeout(() => existingDropdown.remove(), 300);
            this.classList.remove('active');
            return;
          }

          // Закрываем все другие открытые вкладки в этой секции
          const chart = this.closest('.rates-chart');
          chart.querySelectorAll('.states-dropdown').forEach(dropdown => {
            dropdown.style.maxHeight = '0';
            dropdown.style.opacity = '0';
            setTimeout(() => dropdown.remove(), 300);
          });
          chart.querySelectorAll('.rate-bar-modern').forEach(b => b.classList.remove('active'));

          // Создаем выпадающую вкладку
          const dropdown = document.createElement('div');
